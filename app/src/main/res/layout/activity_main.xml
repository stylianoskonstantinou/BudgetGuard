<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BudgetGuard"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="20dp"/>

        <TextView
            android:id="@+id/tvDashboardExpenses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Συνολικά Έξοδα: 0 €"
            android:textSize="18sp"
            android:padding="10dp"/>

        <TextView
            android:id="@+id/tvDashboardBudget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Συνολικό Budget: 1000 €"
            android:textSize="18sp"
            android:padding="10dp"/>

        <TextView
            android:id="@+id/tvDashboardRemaining"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Υπόλοιπο: 1000 €"
            android:textSize="18sp"
            android:padding="10dp"/>

        <Button
            android:id="@+id/btnAddTransaction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Προσθήκη Εξόδου"/>

        <Button
            android:id="@+id/btnViewTransactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Προβολή Συναλλαγών"/>

        <Button
            android:id="@+id/btnBudget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Όρια Προϋπολογισμού"/>

        <Button
            android:id="@+id/btnReports"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Αναφορές"/>

    </LinearLayout>
</ScrollView>